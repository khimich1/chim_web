# PostgreSQL (app DB) — used from Task 1+
# Local dev (no PostgreSQL): sqlite+aiosqlite:///./data/app.db
# Docker / production: postgresql+asyncpg://user:pass@localhost:5432/chemistry
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Content SQLite (read-only), paths relative to backend/ or absolute
CONTENT_EGE_DB_PATH=../test_ege.db
CONTENT_OGE_DB_PATH=../test_oge.db
CONTENT_LECTURES_DB_PATH=../prepared_lectures.db

# Auth — used from Task 4+
# Use a long random secret in production (>= 32 bytes), e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Auth cookie. COOKIE_SECURE must be true behind HTTPS in production.
COOKIE_NAME=access_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# CORS — used from Task 1+
# Local Next dev: http://localhost:3000
# Docker Compose (nginx): http://localhost:8080 — see repo root .env.example
CORS_ORIGINS=http://localhost:3000

# RAG index (v2+ tutor) — built via: python -m app.cli.index_rag --rebuild
# Required for AI tutor: uvicorn + alembic upgrade head + index_rag --rebuild + OPENAI_API_KEY
RAG_INDEX_PATH=backend/data/rag_index.json

# Tutor / LLM (v2+ tutor) — required for agent replies; keyword RAG index works without key
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=5
RAG_HYBRID_ENABLED=true
CHROMA_DIR=backend/data/chroma
