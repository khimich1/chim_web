# Docker Compose — copy to repo root as `.env` (not committed).
# Used by: docker compose up --build

# Public URL users open in the browser (must match nginx host:port).
NGINX_PORT=8080
NEXT_PUBLIC_API_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080

# Auth — generate for real deployments: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
COOKIE_NAME=access_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Optional: tutor / RAG (v2+)
OPENAI_API_KEY=
LOG_LEVEL=INFO

# Content SQLite (read-only) — default paths are /app/*.db inside the backend container.
# To use local files, uncomment volume mounts in docker-compose.yml (files must exist on host).
